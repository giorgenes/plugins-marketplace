{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plugin Manifest",
  "type": "object",
  "required": ["name", "version", "description", "skill"],
  "properties": {
    "name":        { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "version":     { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string" },
    "author":      { "type": "string" },
    "tags":        { "type": "array", "items": { "type": "string" } },
    "skill": {
      "type": "object",
      "required": ["file", "trigger"],
      "properties": {
        "file":    { "type": "string", "description": "Relative path to the SKILL.md file" },
        "trigger": { "type": "string", "description": "Natural-language description of when Claude should invoke this skill" }
      }
    }
  }
}
